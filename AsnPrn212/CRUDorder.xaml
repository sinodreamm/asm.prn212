<Window x:Class="AsnPrn212.CRUDorder"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AsnPrn212"
        mc:Ignorable="d"
        Title="Order Management" Height="480" Width="500"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Update / Add Order Dashboard" 
                   TextAlignment="Center" VerticalAlignment="Center" 
                   FontSize="18" FontWeight="Bold" Margin="0,10,0,20"/>

        <StackPanel Grid.Row="1" Margin="20,0,20,0">
            <!-- Customer Type Selection -->
            <DockPanel Margin="0,0,0,5">
                <Label Content="Customer Type:" DockPanel.Dock="Left" Width="120" FontWeight="SemiBold"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <RadioButton Name="rbRegistered" Content="Registered" IsChecked="True" Checked="CustomerType_Changed" Margin="0,0,15,0"/>
                    <RadioButton Name="rbGuest" Content="Guest" Checked="CustomerType_Changed"/>
                </StackPanel>
            </DockPanel>

            <!-- Customer Search -->
            <DockPanel Margin="0,0,0,10" Name="panelSearchCustomer">
                <Label Content="Search Customer:" DockPanel.Dock="Left" Width="120" FontWeight="SemiBold"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Name="txtCustomerSearch" Grid.Column="0" VerticalContentAlignment="Center" Margin="0,0,5,0" ToolTip="Enter name or phone"/>
                    <Button Name="btnSearchCustomer" Grid.Column="1" Content="Search" Width="60" Click="btnSearchCustomer_Click"/>
                </Grid>
            </DockPanel>

            <!-- Customer Result -->
            <DockPanel Margin="0,0,0,10" Name="panelCustomerResult">
                <Label Content="Select Result:" DockPanel.Dock="Left" Width="120" FontWeight="SemiBold"/>
                <ComboBox Name="cboCustomer" DisplayMemberPath="FullName" SelectedValuePath="Id" VerticalContentAlignment="Center"/>
            </DockPanel>

            <!-- Saler -->
            <DockPanel Margin="0,0,0,10">
                <Label Content="Saler:" DockPanel.Dock="Left" Width="120" FontWeight="SemiBold"/>
                <ComboBox Name="cboSaler" DisplayMemberPath="FullName" SelectedValuePath="Id" VerticalContentAlignment="Center"/>
            </DockPanel>

            <!-- Delivery Worker -->
            <DockPanel Margin="0,0,0,10">
                <Label Content="Delivery Worker:" DockPanel.Dock="Left" Width="120" FontWeight="SemiBold"/>
                <ComboBox Name="cboDelivery" DisplayMemberPath="FullName" SelectedValuePath="Id" VerticalContentAlignment="Center"/>
            </DockPanel>

            <!-- Order Date -->
            <DockPanel Margin="0,0,0,10">
                <Label Content="Order Date:" DockPanel.Dock="Left" Width="120" FontWeight="SemiBold"/>
                <DatePicker Name="dpOrderDate" SelectedDate="{Binding OrderDate}"/>
            </DockPanel>

            <!-- Total Amount -->
            <DockPanel Margin="0,0,0,10">
                <Label Content="Total Amount:" DockPanel.Dock="Left" Width="120" FontWeight="SemiBold"/>
                <TextBox Name="txtTotalAmount" Text="{Binding TotalAmount, StringFormat=N0}" VerticalContentAlignment="Center" />
            </DockPanel>
            
            <!-- Payment Method -->
            <DockPanel Margin="0,0,0,10">
                <Label Content="Payment Method:" DockPanel.Dock="Left" Width="120" FontWeight="SemiBold"/>
                <ComboBox Name="cboPaymentMethod" Text="{Binding PaymentMethod}">
                    <ComboBoxItem Content="Cash" />
                    <ComboBoxItem Content="Bank Transfer" />
                    <ComboBoxItem Content="Credit Card" /> 
                </ComboBox>
            </DockPanel>

            <!-- Status -->
            <DockPanel Margin="0,0,0,10">
                <Label Content="Status:" DockPanel.Dock="Left" Width="120" FontWeight="SemiBold"/>
                <ComboBox Name="cboStatus" Text="{Binding Status}">
                    <ComboBoxItem Content="Pending"  />
                    <ComboBoxItem Content="Processing" />
                    <ComboBoxItem Content="Completed" />
                    <ComboBoxItem Content="Cancelled" />
                </ComboBox>
            </DockPanel>
        </StackPanel>
        
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,10">
            <Button Name="btnAdd" Content="Add Order" Padding="15,8" Margin="10,0" Width="100" Click="btnAdd_Click"/>
            <Button Name="btnUpdate" Content="Update Order" Padding="15,8" Margin="10,0" Width="100" Click="btnUpdate_Click"/>
            <Button Content="Close" Padding="15,8" Margin="10,0" Width="80" Click="Button_Click"/>
        </StackPanel>
    </Grid>
</Window>