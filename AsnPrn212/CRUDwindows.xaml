<Window x:Class="AsnPrn212.CRUDwindows"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AsnPrn212"
        mc:Ignorable="d"
        Title="CRUDwindows" Height="400" Width="500"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="3*"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Update / Add User DashBoard" 
                   TextAlignment="Center" VerticalAlignment="Center" 
                   FontSize="16" FontWeight="Bold"/>

        <StackPanel Grid.Row="1" Margin="20,10,20,0">

            <DockPanel>
                <Label Content="UserName :" DockPanel.Dock="Left" Width="80"/>
                <TextBox Name="txtUsername" Text="{Binding Username}" VerticalContentAlignment="Center"/>
            </DockPanel>

            <DockPanel Margin="0,10,0,10">
                <Label Content="PassWord :" DockPanel.Dock="Left" Width="80"/>
                <TextBox Name="txtPassword" Text="{Binding PasswordHash}" VerticalContentAlignment="Center" />
            </DockPanel>
            <DockPanel Margin="0,0,0,10">
                <Label Content="FullName :" DockPanel.Dock="Left" Width="80"/>
                <TextBox Name="txtFullname" Text="{Binding FullName}" VerticalContentAlignment="Center" />
            </DockPanel>
            <DockPanel Margin="0,0,0,10" >
                <Label Content="Email :" DockPanel.Dock="Left" Width="80"/>
                <TextBox Name="txtEmail" Text="{Binding Email}" VerticalContentAlignment="Center" />
            </DockPanel>

            <DockPanel Margin="0,0,0,10">
                <Label Content="Phone :" DockPanel.Dock="Left" Width="80"/>
                <TextBox Name="txtPhone" Text="{Binding Phone}" VerticalContentAlignment="Center" />
            </DockPanel>
            
            <DockPanel Margin="0,0,0,10">
                <Label Content="Role :" DockPanel.Dock="Left" Width="80"/>
                <ComboBox Name="comboRole" Text="{Binding Role}">
                    <ComboBoxItem Content="Customer"  />
                    <ComboBoxItem Content="Saler" />
                    <ComboBoxItem Content="Delivery" />
                    <ComboBoxItem Content="Guest" />
                </ComboBox>
            </DockPanel>
            

        </StackPanel>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Name="btnAdd" Content="Add" Padding="10" Margin="20" Width="70" Click="btnAdd_Click"></Button>
            <Button Name="btnUpdate" Content="Update" Padding="10" Margin="20" Width="70" Click="btnUpdate_Click"></Button>
            <Button Content="Close" Padding="10" Margin="20" Width="70" Click="Button_Click"></Button>
        </StackPanel>

    </Grid>
</Window>