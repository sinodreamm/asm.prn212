<Window x:Class="AsnPrn212.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ControlApp" Height="600" Width="900" WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" TabStripPlacement="Left">

            <TabItem Header="Manager Account" Padding="15,10">
                <Grid Margin="15,5,5,5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,15">
                        <TextBlock Text="Manager Account" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Reload" Padding="15,5" Margin="10,0,0,0" Click="Button_Click"/>
                            <Button Name="btnAddUser" Content="Add User" Padding="15,5" Margin="10,0,0,0" Click="btnAddUser_Click"/>
                            <Button Name="btnUpdateUser" Content="Update" Padding="15,5" Margin="10,0,0,0" Click="btnUpdateUser_Click"/>
                            <Button Name="btnDeleteUser" Content="Delete User" Padding="15,5" Margin="10,0,0,0" Click="btnDeleteUser_Click"/>
                        </StackPanel>
                    </Grid>


                    <DataGrid Grid.Row="1" 
                              Name="dgAccount" 
                              AutoGenerateColumns="False" 
                              CanUserAddRows="False" 
                              
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Full Name" Binding="{Binding Username}" Width="*"/>

                            <DataGridTextColumn Header="Phone" Binding="{Binding PasswordHash}" Width="*"/>


                            <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}" Width="*"/>

                            <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="*"/>
                            

                            <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="200"/>

                        </DataGrid.Columns>

                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Manager Order" Padding="15,10">
                <Grid Margin="15,5,5,5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,15">
                        <TextBlock Text="Manager Order" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Reload" Padding="15,5" Margin="10,0,0,0" Click="Button_Click_1"/>
                            <Button Name="btnAddOrder" Content="Add Order" Padding="15,5" Margin="10,0,0,0" Click="btnAddOrder_Click"/>
                            <Button Name="btnDeleteOrder" Content="Delete Order" Padding="15,5" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Grid>

                    <DataGrid Grid.Row="1" Name="dgOrder" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
                        <!-- Binding các cột chính của Order và Customer -->
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Mã Đơn" Binding="{Binding Id}" Width="80"/>
                            <DataGridTextColumn Header="Tên Khách Hàng" Binding="{Binding Customer.FullName}" Width="*"/>
                            <DataGridTextColumn Header="Người Bán" Binding="{Binding Saler.FullName}" Width="*"/>
                            <DataGridTextColumn Header="Người Giao" Binding="{Binding DeliveryWorker.FullName}" Width="*"/>
                            <DataGridTextColumn Header="Ngày Đặt" Binding="{Binding OrderDate, StringFormat=dd/MM/yyyy HH:mm}" Width="150"/>
                            <DataGridTextColumn Header="Tổng Tiền" Binding="{Binding TotalAmount, StringFormat=C0}" Width="150"/>
                            <DataGridTextColumn Header="Trạng Thái" Binding="{Binding Status}" Width="120"/>
                            <DataGridTextColumn Header="Thanh Toán" Binding="{Binding PaymentMethod}" Width="120"/>
                        </DataGrid.Columns>
                        <DataGrid.RowDetailsTemplate>
                            <DataTemplate>
                                <Border Margin="20,10,10,10" Padding="10" Background="#f9f9f9" BorderBrush="LightGray" BorderThickness="1" CornerRadius="5">
                                    <StackPanel>
                                        <TextBlock Text="Chi tiết sản phẩm:" FontWeight="Bold" Margin="0,0,0,5"/>
                                        <DataGrid ItemsSource="{Binding OrderDetails}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" HeadersVisibility="Column" Background="White">
                                            <DataGrid.Columns>
                                                <!-- Lấy Tên sản phẩm từ bảng Product -->
                                                <DataGridTextColumn Header="Tên Sản Phẩm" Binding="{Binding Product.Name}" Width="200"/>
                                                <DataGridTextColumn Header="Số Lượng" Binding="{Binding Quantity}" Width="100"/>
                                                <DataGridTextColumn Header="Đơn Giá" Binding="{Binding UnitPrice, StringFormat=C0}" Width="150"/>
                                                <!-- Tính thành tiền từng món -->
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </DataGrid.RowDetailsTemplate>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Report Static" Padding="15,10">
                <Grid Margin="15,5,5,5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,15">
                        <TextBlock Text="Report &amp; Statistics" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button Content="Export Report" Padding="15,5" HorizontalAlignment="Right"/>
                    </Grid>

                    <DataGrid Grid.Row="1" Name="dgReport" AutoGenerateColumns="True" CanUserAddRows="False">

                    </DataGrid>
                </Grid>
            </TabItem>

        </TabControl>

        <Button Grid.Row="1" Name="btnLogout" Content="Log Out" Padding="10" Margin="5,10,0,0" HorizontalAlignment="Left" Width="110"/>

    </Grid>
</Window>